      "parameters": {
        "jsCode": "// Log del resultado para debugging\nconst items = $input.all();\nconst fileName = $('Google Drive - Download').first().json.name || 'desconocido';\n\nconsole.log(`✅ PDF procesado: ${fileName} - ${items.length} chunks insertados`);\n\nreturn [{\n  json: {\n    status: 'ok',\n    file: fileName,\n    chunks_inserted: items.length,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
