    {
      "parameters": {
        "jsCode": "const pages = $input.first().json.pages || [];\nconst loopItem = $('Loop Over Items').item.json;\nconst fileName = loopItem.name || 'sin_nombre';\nconst fileId = loopItem.id || '';\n\nconsole.log('Procesando:', fileName, '- páginas:', pages.length);\n\nif (pages.length === 0) {\n  return [{ json: { text: 'sin contenido', metadata: { source: fileName, file_id: fileId, page: 0, chunk_index: 0 } } }];\n}\n\nconst chunks = [];\nfor (const page of pages) {\n  const text = (page.text || '').trim();\n  if (text.length < 50) continue;\n  chunks.push({\n    json: {\n      text: text,\n      metadata: {\n        source: fileName,\n        file_id: fileId,\n        page: page.page || 0,\n        chunk_index: chunks.length\n      }\n    }\n  });\n}\n\nif (chunks.length === 0) {\n  return [{ json: { text: 'sin contenido', metadata: { source: fileName, file_id: fileId, page: 0, chunk_index: 0 } } }];\n}\n\nreturn chunks;"
      },
      "id": "4b478d4c-7df3-4efe-ba44-df6d2c5dcf1a",
